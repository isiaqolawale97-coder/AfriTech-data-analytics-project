--Exploratory Data Analysis
--likes across platform
SELECT Platform, SUM(EngagementLikes) AS Total_likes, ROUND(AVG(EngagementLikes),2) AS Average_likes FROM SocialMedia 
GROUP BY Platform
ORDER BY SUM(EngagementLikes);

--comment across platform 
SELECT Platform, SUM(EngagementComments) AS Total_comments, ROUND(AVG(EngagementComments),2) AS Average_Comments FROM SocialMedia 
GROUP BY Platform
ORDER BY SUM(EngagementComments);

--Shares across platform
SELECT Platform, SUM(EngagementShares) AS Total_shares, ROUND(AVG(EngagementShares),2) AS Average_Shares FROM SocialMedia 
GROUP BY Platform
ORDER BY SUM(EngagementShares);

--sentiment distribution 
SELECT Platform,Sentiment, COUNT (*) AS Sentiment_count FROM SocialMedia
GROUP BY Platform,Sentiment
ORDER BY Platform;

--Month by Month breakdown of likes,comments and shares
SELECT EXTRACT (MONTH FROM InteractionDate) AS MONTH,
   SUM(EngagementLikes) AS total_likes, 
   SUM(EngagementComments) AS total_comments, 
   SUM(EngagementShares) AS total_shares
FROM socialmedia
GROUP BY EXTRACT (MONTH FROM InteractionDate)
ORDER BY EXTRACT (MONTH FROM InteractionDate);


SELECT To_char(InteractionDate,'mon') AS MONTH,
   SUM(EngagementLikes) AS total_likes, 
   SUM(EngagementComments) AS total_comments, 
   SUM(EngagementShares) AS total_shares
FROM socialmedia
GROUP BY To_char(InteractionDate,'mon'), EXTRACT (MONTH FROM InteractionDate)
ORDER BY EXTRACT (MONTH FROM InteractionDate);


--Brand mention vs competitor mentions 
      SELECT SUM(CASE
