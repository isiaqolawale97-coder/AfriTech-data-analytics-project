--breakdown of brandmention vs competitor mention month and year 
  SELECT EXTRACT(YEAR FROM InteractionDATE ) AS YEAR,
         TO_CHAR(InteractionDate,'mon') AS MONTH,
		 SUM(CASE
		 WHEN BrandMention ='true' THEN 1
		 ELSE 0
		 END)AS BrandmentionCOUNT,
		 SUM(CASE
		 WHEN CompetitorMention ='true'THEN 1
		 ELSE 0
		 END) AS competitormentionCount
 FROM SocialMedia
 GROUP BY EXTRACT(YEAR FROM InteractionDATE),TO_CHAR(InteractionDate,'mon')
 ORDER BY EXTRACT(YEAR FROM InteractionDate);

 --Brand mention and competitormention on platform
  SELECT platform, SUM(CASE
      WHEN brandmention ='true' THEN 1
	  ELSE 0
	  END)AS BrandMentionCount,
	  SUM(CASE
	  WHEN Competitormention ='true' THEN 1
	  ELSE 0
	  END)AS CompetitormentionCount 
from SocialMedia
